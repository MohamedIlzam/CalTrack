generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// Enums
enum Goal {
  LOSE
  MAINTAIN
  GAIN
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
}

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
  SNACKS
}

enum ModerationStatus {
  SUBMITTED
  VALIDATION_PASSED
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

// User Profile
model User {
  id             String        @id @default(uuid())
  email          String        @unique
  name           String
  passwordHash   String
  weightKg       Float?
  targetWeightKg Float?
  heightCm       Float?
  goal           Goal          @default(LOSE)
  activityLevel  ActivityLevel @default(SEDENTARY)
  
  targetCalories Int?
  targetProteinG Int?
  targetCarbsG   Int?
  targetFatG     Int?

  mealLogs       MealLog[]
  weightEntries  WeightEntry[]

  timezone       String        @default("Asia/Colombo")

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// Regions
model Region {
  id       String  @id // e.g. "LK", "US", "GB"
  name     String
  currency String  @default("LKR")
  brands   Brand[]
  foods    Food[]
}

// Brands
model Brand {
  id        String   @id @default(uuid())
  name      String
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id])
  foods     Food[]
  createdAt DateTime @default(now())

  @@unique([name, regionId])
}

// Master Foods Table
model Food {
  id              String   @id @default(uuid())
  brandId         String?
  brand           Brand?   @relation(fields: [brandId], references: [id])
  regionId        String
  region          Region   @relation(fields: [regionId], references: [id])
  name            String
  category        String   // "staples", "curries", "bakery"
  isVerified      Boolean  @default(false)
  
  // Nutrients per 100g/mL
  caloriesKcal    Float
  proteinG        Float
  carbohydratesG  Float
  fatG            Float
  saturatedFatG   Float    @default(0.0)
  fiberG          Float    @default(0.0)
  sodiumMg        Float    @default(0.0)
  waterG          Float    @default(0.0)

  aliases         FoodAlias[]
  unitConversions UnitConversion[]
  mealLogs        MealLogEntry[]
  embedding       FoodEmbedding?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Food Aliases for multilingual search
model FoodAlias {
  id           String @id @default(uuid())
  foodId       String
  food         Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)
  aliasName    String
  languageCode String @default("en") // 'en', 'si', 'ta'

  @@unique([foodId, aliasName])
  @@index([aliasName])
}

// Unit Conversions
model UnitConversion {
  id             String  @id @default(uuid())
  foodId         String
  food           Food    @relation(fields: [foodId], references: [id], onDelete: Cascade)
  unitName       String  // e.g. 'piece', 'plate', 'cup'
  gramEquivalent Float
  isStandard     Boolean @default(false)

  @@unique([foodId, unitName])
}

// Vector Embeddings
model FoodEmbedding {
  foodId    String                      @id
  food      Food                        @relation(fields: [foodId], references: [id], onDelete: Cascade)
  embedding Unsupported("vector(384)")
}

// Meal Log
model MealLog {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime       @db.Date
  entries   MealLogEntry[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([userId, date])
}

// Meal Log Entry
model MealLogEntry {
  id                  String   @id @default(uuid())
  mealLogId           String
  mealLog             MealLog  @relation(fields: [mealLogId], references: [id], onDelete: Cascade)
  foodId              String?
  food                Food?    @relation(fields: [foodId], references: [id], onDelete: SetNull)
  meal                MealSlot
  servingQuantity     Float
  unitName            String
  loggedWeightGrams   Float
  
  // Denormalized macros
  loggedCaloriesKcal  Float
  loggedProteinG      Float
  loggedCarbohydratesG Float
  loggedFatG          Float
  
  createdAt           DateTime @default(now())
}

// Moderation Queue for user-submitted foods
model ModerationQueue {
  id              String           @id @default(uuid())
  stagingFoodId   String           // Maps to a temporary JSON or holding table record
  moderatorId     String?
  status          ModerationStatus @default(SUBMITTED)
  rejectionReason String?
  automatedLogs   String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

// Weight Entries
model WeightEntry {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg   Float
  recordedAt DateTime @default(now())

  @@index([userId, recordedAt])
}
